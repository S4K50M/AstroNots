.shell { min-height: 100vh; display: flex; flex-direction: column; }

.layout {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 360px;
  min-height: 0;
}

.left {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  overflow-y: auto;
}

.mapWrap {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
  min-height: 340px;
}
.mapTopBar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.mapLabel { font-family: var(--mono); font-size: 10px; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; }
.mapMeta  { font-family: var(--mono); font-size: 11px; color: var(--aurora); }

.right {
  border-left: 1px solid var(--border);
  background: var(--bg1);
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  overflow-y: auto;
}

/* Location row */
.locRow { display: flex; gap: 8px; }
.locInput {
  flex: 1;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 7px;
  padding: 8px 10px;
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text);
  outline: none;
  min-width: 0;
  transition: border-color 0.2s;
}
.locInput:focus { border-color: var(--border-bright); }
.locInput::placeholder { color: var(--text-dim); }
.locBtn {
  background: var(--aurora-glow);
  border: 1px solid var(--border-bright);
  border-radius: 7px;
  padding: 8px 14px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--aurora);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}
.locBtn:hover { background: rgba(0,255,163,0.18); }

/* Tabs */
.tabs { display: flex; gap: 4px; }
.tab {
  flex: 1;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 7px;
  padding: 7px 4px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-muted);
  cursor: pointer;
  letter-spacing: 0.06em;
  transition: all 0.15s;
}
.tab:hover { color: var(--text); border-color: rgba(255,255,255,0.12); }
.tabActive { color: var(--aurora) !important; border-color: var(--border-bright) !important; background: var(--aurora-glow) !important; }
.tabContent { flex: 1; }

/* Alerts tab */
.sectionLabel {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--text-dim);
  padding-bottom: 10px; border-bottom: 1px solid var(--border);
  margin-bottom: 10px;
}
.alertsList { display: flex; flex-direction: column; gap: 8px; }
.alertItem {
  padding: 10px 12px;
  border-radius: 8px;
  border-left: 3px solid var(--amber);
  background: var(--bg2);
}
.wsAlert { border-left-color: var(--teal); }
.alertSev { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--amber); letter-spacing: 0.08em; margin-bottom: 4px; }
.alertMsg { font-family: var(--mono); font-size: 11px; color: var(--text-muted); line-height: 1.5; }
.noAlerts { font-family: var(--mono); font-size: 12px; color: var(--text-dim); }

/* Mobile */
@media (max-width: 768px) {
  .layout { grid-template-columns: 1fr; }
  .right  { border-left: none; border-top: 1px solid var(--border); }
}
