# Application
DEBUG=false
APP_NAME=Aurora Nowcast
APP_VERSION=1.0.0

# NOAA SWPC Endpoints
NOAA_BASE_URL=https://services.swpc.noaa.gov
MAG_ENDPOINT=/products/solar-wind/mag-1-day.json
PLASMA_ENDPOINT=/products/solar-wind/plasma-1-day.json
OVATION_ENDPOINT=/json/ovation_aurora_latest.json
KP_ENDPOINT=/products/noaa-planetary-k-index.json
ALERTS_ENDPOINT=/products/alerts.json

# Alert Thresholds
BZ_ALERT_THRESHOLD=-7.0
SOLAR_WIND_SPEED_THRESHOLD=500.0
BZ_SUBSTORM_RATE_THRESHOLD=-2.0

# Polling Intervals (seconds)
MAG_POLL_INTERVAL=60
PLASMA_POLL_INTERVAL=60
OVATION_POLL_INTERVAL=1800
KP_POLL_INTERVAL=600
ALERTS_POLL_INTERVAL=300

# HTTP Client
HTTP_TIMEOUT=10
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF=2.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Meteoblue API (optional - for advanced weather data)
METEOBLUE_API_KEY=your_key_here_if_you_have_one