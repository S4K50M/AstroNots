# Aurora Intelligence Platform — Backend Environment
# Copy to .env and adjust as needed

# Polling intervals (seconds)
MAG_POLL_INTERVAL=60
PLASMA_POLL_INTERVAL=60
OVATION_POLL_INTERVAL=1800
KP_POLL_INTERVAL=180
ALERTS_POLL_INTERVAL=60

# Alert thresholds
BZ_ALERT_THRESHOLD=-7.0
SOLAR_WIND_SPEED_THRESHOLD=500.0
BZ_SUBSTORM_RATE_THRESHOLD=-2.0

# CORS — add your deployed frontend URL here
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Debug mode (enables coloured console logs instead of JSON)
DEBUG=true
